# Copy this file to .env and fill in the values.
# docker compose reads .env automatically.

# ---- JWT ----
JWT_SECRET=mySecretKeyForJWTTokenGenerationThatIsAtLeast256BitsLongForHS256Algorithm

# ---- Stripe (test keys for development) ----
# Get them from https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook secret is generated by `stripe listen --forward-to localhost:8080/api/storefront/checkout/webhook`
# and by the Stripe Dashboard when you create a webhook endpoint. Leave blank in local dev if you are
# not running the webhook forwarder.
STRIPE_WEBHOOK_SECRET=

# ISO-4217 three-letter currency the checkout charges in (try, usd, eur, ...).
STRIPE_CURRENCY=try
