# Copy this file to .env and fill in the values.
# docker compose reads .env automatically.
#
# SECURITY: Never commit the real .env. .env is already in .gitignore and .dockerignore.
# Rotate every secret below before a production deploy.

# ---- JWT ----
# REQUIRED. Generate with:  openssl rand -base64 48
# Must be at least 256 bits of entropy. Must NOT be reused across environments.
JWT_SECRET=

# Access-token TTL in milliseconds. 15 minutes is a reasonable default.
JWT_EXPIRATION_MS=900000

# Claims the backend stamps into every JWT and verifies on every request.
JWT_ISSUER=shoestore-backend
JWT_AUDIENCE=shoestore-clients

# ---- One-time order-lookup token (customer checkout) ----
# Signs short-lived HMAC tokens so customers can retrieve their own orders
# without logging in, but strangers cannot enumerate order IDs. If unset,
# falls back to JWT_SECRET.
ORDER_TOKEN_SECRET=
ORDER_TOKEN_TTL_MS=604800000

# ---- Bootstrap admin (first boot only) ----
# A single admin account is created on first boot if the users table is empty.
# After that, log in and create additional users via the admin panel.
# Change this before deploying!
BOOTSTRAP_USERS_ENABLED=true
BOOTSTRAP_ADMIN_USERNAME=admin
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_EMAIL=admin@shoestore.local

# ---- CORS ----
# Comma-separated list of browser origins allowed to call the API. Tight list in prod.
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ---- Database ----
# Used by docker-compose. No default in the code — explicit values required.
POSTGRES_DB=shoestore
POSTGRES_USER=postgres
POSTGRES_PASSWORD=

# ---- Stripe (test keys for development) ----
# Get them from https://dashboard.stripe.com/test/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx

# Webhook secret is generated by `stripe listen --forward-to localhost:8080/api/storefront/checkout/webhook`
# and by the Stripe Dashboard when you create a webhook endpoint.
# REQUIRED in production — the backend refuses to confirm orders without a verified webhook.
STRIPE_WEBHOOK_SECRET=

# ISO-4217 three-letter currency the checkout charges in (try, usd, eur, ...).
STRIPE_CURRENCY=try

# ---- AI image generation (server-side only) ----
# Used by the admin panel through the backend so the key is never exposed in browser devtools.
AI_IMAGE_API_KEY=
AI_IMAGE_MODEL=gemini-2.5-flash-image
AI_IMAGE_MAX_BYTES=10000000

# ---- Order-confirmation email (SMTP) ----
# Leave SPRING_MAIL_HOST blank to disable email entirely. With a blank host
# the backend boots cleanly and OrderEmailService logs an INFO line each
# time it would have sent — useful for local dev without an SMTP relay.
#
# Gmail example (use an App Password, not your account password):
#   SPRING_MAIL_HOST=smtp.gmail.com
#   SPRING_MAIL_PORT=587
#   SPRING_MAIL_USERNAME=your-shop@gmail.com
#   SPRING_MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx
#
# Mailtrap (free dev inbox; great for testing without spamming real users):
#   SPRING_MAIL_HOST=sandbox.smtp.mailtrap.io
#   SPRING_MAIL_PORT=2525
#   SPRING_MAIL_USERNAME=<mailtrap-inbox-username>
#   SPRING_MAIL_PASSWORD=<mailtrap-inbox-password>
SPRING_MAIL_HOST=
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=
SPRING_MAIL_PASSWORD=
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_STARTTLS=true

# `From` header on outbound mail. Most relays demand this match the
# authenticated mailbox; pick something your SMTP provider will accept.
APP_MAIL_FROM=Steps Store <noreply@example.com>

# Public origin used to build the absolute "Track your order" link in
# the email. Set to whatever URL the customer reaches the gateway on.
APP_PUBLIC_BASE_URL=http://localhost:3000

# ---- Logging ----
APP_LOG_LEVEL=INFO
